{
  "version": 2,
  "installCommand": "npm install && npm --prefix backend install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "backend/src/serverless.js": {
      "runtime": "@vercel/node@3.2.20",
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/src/serverless.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
