{
  "version": 2,
  "installCommand": "npm install && npm --prefix backend install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/[...all].js": {
      "runtime": "@vercel/node@3.2.20",
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/[...all].js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
